<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (light). -->
    <style name="Theme.ThaiFlickKeyboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/key_indigo</item>
        <item name="colorPrimaryVariant">@color/key_indigo</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/key_green</item>
        <item name="colorSecondaryVariant">@color/key_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#000000</item>
        <item name="android:statusBarColor">#F2F2F7</item>
        <item name="android:navigationBarColor">#F2F2F7</item>
        <item name="android:windowBackground">#F2F2F7</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ThaiFlickKeyboard.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/key_indigo</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorPrimary">#000000</item>
    </style>
</resources>
