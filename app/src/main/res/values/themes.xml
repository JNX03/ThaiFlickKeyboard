<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ThaiFlickKeyboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/key_indigo</item>
        <item name="colorPrimaryVariant">#1C1C1E</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/key_green</item>
        <item name="colorSecondaryVariant">@color/key_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">#1C1C1E</item>
        <item name="android:navigationBarColor">#1C1C1E</item>
        <item name="android:windowBackground">#1C1C1E</item>
    </style>

    <style name="Theme.ThaiFlickKeyboard.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/key_indigo</item>
        <item name="android:background">#2C2C2E</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>
</resources>