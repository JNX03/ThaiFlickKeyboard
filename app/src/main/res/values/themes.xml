<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ThaiFlickKeyboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/key_indigo</item>
        <item name="colorPrimaryVariant">@color/keyboard_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/key_green</item>
        <item name="colorSecondaryVariant">@color/key_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/keyboard_background</item>
        <item name="android:navigationBarColor">@color/keyboard_background</item>
        <item name="android:windowBackground">@color/keyboard_background</item>
    </style>
</resources>