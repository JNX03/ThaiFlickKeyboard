<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingBottom="4dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/keyboard_not_enabled"
            android:textSize="13sp"
            android:textColor="#FF453A"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp" />

        <!-- Section: Setup -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Enable Keyboard -->
        <LinearLayout
            android:id="@+id/row_enable"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_keyboard" android:layout_marginEnd="16dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Enable Keyboard"
                android:textSize="16sp" android:textColor="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:textColor="#8E8E93" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2C2C2E" android:layout_marginStart="60dp" />

        <!-- Select Keyboard -->
        <LinearLayout
            android:id="@+id/row_select"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_language_switch" android:layout_marginEnd="16dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Select Keyboard"
                android:textSize="16sp" android:textColor="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:textColor="#8E8E93" />
        </LinearLayout>

        <!-- Section: Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Input"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <!-- Layout Preset -->
        <LinearLayout
            android:id="@+id/row_preset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_layout" android:layout_marginEnd="16dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Layout Preset" android:textSize="16sp" android:textColor="#FFFFFF" />
                <TextView android:id="@+id/tv_preset_value" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Optimized (Center)"
                    android:textSize="12sp" android:textColor="#8E8E93" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:textColor="#8E8E93" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2C2C2E" android:layout_marginStart="60dp" />

        <!-- Customize Keys -->
        <LinearLayout
            android:id="@+id/row_customize"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_tune" android:layout_marginEnd="16dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Customize Keys"
                android:textSize="16sp" android:textColor="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:textColor="#8E8E93" />
        </LinearLayout>

        <!-- Section: Preferences -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferences"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <!-- Haptic Feedback -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_vibration" android:layout_marginEnd="16dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/pref_haptic"
                android:textSize="16sp" android:textColor="#FFFFFF" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_haptic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2C2C2E" android:layout_marginStart="60dp" />

        <!-- Key Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_volume" android:layout_marginEnd="16dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/pref_sound"
                android:textSize="16sp" android:textColor="#FFFFFF" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Section: Test -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:hint="Try typing here…"
            app:boxBackgroundColor="#2C2C2E"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:hintTextColor="#8E8E93">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:minLines="3"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
